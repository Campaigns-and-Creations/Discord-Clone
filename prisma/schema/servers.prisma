model Server {
    id          String   @id @default(uuid())
    name        String
    picture     String?
    createdAt   DateTime @default(now())
    channels    Channel[]
    members     ServerMember[]
    roles       ServerRoles[]
    invites     ServerInvite[]
}

model Channel {
    id          String   @id @default(uuid())
    name        String
    serverId    String
    server      Server   @relation(fields: [serverId], references: [id])
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    type        ChannelType
    isPublic    Boolean  @default(true)
    messages    Messages[]
    users       User[]   @relation("ChannelUsers")
    allowedRoles ChannelRoleAccess[]
}

model ServerMember {
    id          String   @id @default(uuid())
    userId      String
    serverId    String
    server      Server   @relation(fields: [serverId], references: [id])
    user        User     @relation(fields: [userId], references: [id])
    timeoutUntil DateTime?
    serverRoles ServerRoles[] @relation("ServerMemberRoles")
}

model ServerRoles {
    id          String   @id @default(uuid())
    name        String
    position    Int      @default(0)
    serverId    String
    server      Server   @relation(fields: [serverId], references: [id])
    members     ServerMember[] @relation("ServerMemberRoles")
    permissions ServerRolePermission[]
    channelAccess ChannelRoleAccess[]

    @@unique([serverId, name])
}

model ChannelRoleAccess {
    id         String      @id @default(uuid())
    channelId  String
    channel    Channel     @relation(fields: [channelId], references: [id], onDelete: Cascade)
    roleId     String
    role       ServerRoles @relation(fields: [roleId], references: [id], onDelete: Cascade)

    @@unique([channelId, roleId])
    @@index([roleId])
}

model ServerRolePermission {
    id          String      @id @default(uuid())
    roleId      String
    role        ServerRoles @relation(fields: [roleId], references: [id], onDelete: Cascade)
    permission  Permission

    @@unique([roleId, permission])
}

model Messages {
    id          String   @id @default(uuid())
    content     String   @db.Text
    channelId   String
    channel     Channel  @relation(fields: [channelId], references: [id])
    authorId    String
    author      User     @relation(fields: [authorId], references: [id])
    createdAt   DateTime @default(now())
    pinned      Boolean  @default(false)
}

model ServerInvite {
    id           String   @id @default(uuid())
    code         String   @unique @db.VarChar(12)
    serverId     String
    server       Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
    creatorId    String?
    creator      User?    @relation(fields: [creatorId], references: [id], onDelete: SetNull)
    expiresAt    DateTime?
    maxUses      Int?
    currentUses  Int      @default(0)
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt

    @@index([serverId])
    @@index([expiresAt])
}

enum ChannelType {
    TEXT
    VOICE
}

enum Permission {
    ADMINISTRATOR
    MANAGE_SERVER
    MANAGE_CHANNELS
    CREATE_INVITE
    MANAGE_MESSAGES
    PIN_MESSAGES
    MODERATE_MEMBERS
    KICK_MEMBERS
    BAN_MEMBERS
    VIEW_CHANNEL
    SEND_MESSAGES
    READ_MESSAGE_HISTORY
}