{
  "name": "discord_clone",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --fix --max-warnings=0 --no-warn-ignored",
    "server-p": "npx prisma migrate dev && npx prisma generate && npx prisma studio",
    "postinstall": "prisma generate",
    "db:seed": "npx prisma generate && tsx prisma/seed.ts",
    "db:reset": "npx prisma migrate reset && npm run db:seed",
    "db:reset:force": "npx prisma migrate reset --force && npm run db:seed"
  },
  "dependencies": {
    "@mantine/core": "^8.3.15",
    "@mantine/form": "^8.3.15",
    "@mantine/modals": "^8.3.15",
    "@phosphor-icons/react": "^2.1.10",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@stream-io/node-sdk": "^0.7.51",
    "@stream-io/video-react-sdk": "^1.34.2",
    "@tanstack/react-query": "^5.90.21",
    "better-auth": "^1.5.6",
    "dotenv": "^17.4.1",
    "framer-motion": "^12.34.2",
    "next": "16.1.6",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^24.10.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.1.6",
    "prisma": "^7.6.0",
    "tailwindcss": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "prisma": {
    "seed": "npm run db:seed"
  }
}
